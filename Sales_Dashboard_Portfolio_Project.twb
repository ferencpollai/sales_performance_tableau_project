            <run bold='true' fontcolor='#303030'><![CDATA[<[federated.18sywu21tbdn311bx0cvk03mp8li].[sum:Calculation_0256246838321162:qk]> ]]></run>
            <run fontcolor='#303030' fontsize='14'>vs. PY</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Customers+' name='federated.18sywu21tbdn311bx0cvk03mp8li' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.18sywu21tbdn311bx0cvk03mp8li'>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_0094893159411719]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_0094893159473160]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]-1' />
            </column>
            <column caption='CY Customers' datatype='string' name='[Calculation_0256246824878080]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='PY Customers' datatype='string' name='[Calculation_0256246824992769]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='% Diff Customers' datatype='real' default-format='p0.0%' name='[Calculation_0256246825152514]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD([Calculation_0256246824878080]) - COUNTD([Calculation_0256246824992769])) / COUNTD([Calculation_0256246824992769])' />
            </column>
            <column caption='Min/Max Customers' datatype='integer' name='[Calculation_0256246825385987]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_0256246824878080]) = WINDOW_MAX(COUNTD([Calculation_0256246824878080]))&#13;&#10;THEN COUNTD([Calculation_0256246824878080])&#13;&#10;ELSEIF COUNTD([Calculation_0256246824878080]) = WINDOW_MIN(COUNTD([Calculation_0256246824878080]))&#13;&#10;THEN COUNTD([Calculation_0256246824878080])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='{COUNTD([CY Customers])}' datatype='integer' name='[Calculation_0256246834495495]' role='measure' type='quantitative' user:unnamed='KPI Customers'>
              <calculation class='tableau' formula='{COUNTD([Calculation_0256246824878080])}' />
            </column>
            <column caption='{[% Diff Customers]}' datatype='real' name='[Calculation_0256246838321162]' role='measure' type='quantitative' user:unnamed='KPI Customers'>
              <calculation class='tableau' formula='{[Calculation_0256246825152514]}' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
